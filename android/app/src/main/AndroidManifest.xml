<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ua.opivnochi.metrogo">

    <!--
        KyivMetroGO — мінімальний набір дозволів.
        Додаток є офлайн-картою метро. Не збирає даних,
        не використовує геолокацію, не має аналітики.
        INTERNET потрібен виключно для форми зворотного зв'язку (Formspree)
        та динамічного оновлення stations.json.
    -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Стандартний Capacitor-дозвіл: дозволяє WebView отримувати
        доступ до мережі навіть у режимі "Background Data Restriction".
        Не є небезпечним (normal protection level).
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false">

        <!--
            usesCleartextTraffic="false" — забороняє HTTP (тільки HTTPS).
            Formspree і YOUR_DOMAIN.com мають підтримувати HTTPS — що вони і роблять.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!--
            FileProvider потрібен для @capacitor/share при експорті бекапу.
            Надає тимчасовий доступ до файлу в Directory.Cache без дозволу
            на читання зовнішнього сховища (READ_EXTERNAL_STORAGE не потрібен).
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
