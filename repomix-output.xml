<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Політика конфіденційності · KyivMetroGO</title>
  <meta name="description" content="KyivMetroGO Privacy Policy — Політика конфіденційності" />
  <style>
    :root {
      --bg:          #0e0e0f;
      --surface:     #18181b;
      --border:      #2a2a2e;
      --accent:      #c8523a;
      --accent-soft: rgba(200, 82, 58, 0.12);
      --text:        #e8e6e3;
      --text-muted:  #8a8784;
      --text-faint:  #4a4846;
      --metro-red:   #e63946;
      --metro-blue:  #5b9bd5;
      --metro-green: #5aaa6a;
      --radius:      10px;
      --font-body:   'Georgia', 'Times New Roman', serif;
      --font-ui:     system-ui, -apple-system, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.75;
      min-height: 100dvh;
    }

    /* ── Шапка ─── */
    header {
      border-bottom: 1px solid var(--border);
      padding: 28px 24px 24px;
    }

    .header-inner {
      max-width: 740px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .logo {
      width: 42px;
      height: 42px;
      background: var(--accent);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .logo svg { width: 24px; height: 24px; }

    .header-text { flex: 1; min-width: 0; }

    .app-name {
      font-family: var(--font-ui);
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: var(--text);
    }

    .app-subtitle {
      font-family: var(--font-ui);
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 1px;
    }

    /* ── Навігація між мовами ─── */
    .lang-switch {
      font-family: var(--font-ui);
      font-size: 13px;
      display: flex;
      gap: 4px;
      flex-shrink: 0;
    }

    .lang-switch a {
      padding: 5px 10px;
      border-radius: 6px;
      text-decoration: none;
      color: var(--text-muted);
      border: 1px solid transparent;
      transition: all 0.15s ease;
    }

    .lang-switch a:hover,
    .lang-switch a.active {
      color: var(--text);
      border-color: var(--border);
      background: var(--surface);
    }

    /* ── Лінії метро — декор ─── */
    .metro-lines {
      height: 3px;
      background: linear-gradient(
        90deg,
        var(--metro-red)   0%,
        var(--metro-red)   33.3%,
        var(--metro-blue)  33.3%,
        var(--metro-blue)  66.6%,
        var(--metro-green) 66.6%,
        var(--metro-green) 100%
      );
      opacity: 0.7;
    }

    /* ── Головний вміст ─── */
    main {
      max-width: 740px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* ── Блок-секція (одна мова) ─── */
    .policy-section {
      padding-top: 48px;
    }

    .policy-section + .policy-section {
      border-top: 1px solid var(--border);
    }

    .section-lang-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-ui);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--accent-soft);
      border: 1px solid rgba(200, 82, 58, 0.25);
      padding: 3px 9px;
      border-radius: 4px;
      margin-bottom: 20px;
    }

    h1 {
      font-family: var(--font-ui);
      font-size: clamp(22px, 5vw, 30px);
      font-weight: 700;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 8px;
      letter-spacing: -0.02em;
    }

    .policy-meta {
      font-family: var(--font-ui);
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 32px;
    }

    /* ── Картка «Важливо» ─── */
    .highlight-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: var(--radius);
      padding: 18px 20px;
      margin-bottom: 36px;
      font-size: 15px;
      line-height: 1.65;
    }

    .highlight-card strong {
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      display: block;
      margin-bottom: 6px;
    }

    /* ── Типографіка тексту ─── */
    h2 {
      font-family: var(--font-ui);
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin: 36px 0 10px;
      letter-spacing: -0.01em;
    }

    p {
      font-size: 15.5px;
      color: #ccc9c5;
      margin-bottom: 14px;
    }

    ul {
      margin: 10px 0 16px 0;
      padding-left: 0;
      list-style: none;
    }

    ul li {
      font-size: 15.5px;
      color: #ccc9c5;
      padding: 5px 0 5px 22px;
      position: relative;
    }

    ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--text-faint);
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover { text-decoration: underline; }

    code {
      font-family: 'SFMono-Regular', 'Consolas', 'Liberation Mono', monospace;
      font-size: 13px;
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      color: #b0ada9;
    }

    /* ── Блок розкриття даних (канали зворотного зв'язку) ─── */
    .channel-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 14px 0 18px;
    }

    .channel-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
    }

    .channel-name {
      font-family: var(--font-ui);
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 6px;
    }

    .channel-sends {
      font-family: var(--font-ui);
      font-size: 12.5px;
      color: var(--text-muted);
    }

    .channel-sends code {
      font-size: 12px;
    }

    /* ── Роздільник між мовами ─── */
    .lang-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 52px 0 0;
      color: var(--text-faint);
      font-family: var(--font-ui);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .lang-divider::before,
    .lang-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Підвал ─── */
    footer {
      border-top: 1px solid var(--border);
      padding: 24px;
      text-align: center;
      font-family: var(--font-ui);
      font-size: 12px;
      color: var(--text-faint);
    }

    /* ── Адаптивність ─── */
    @media (max-width: 480px) {
      header { padding: 20px 16px; }
      main   { padding: 0 16px 60px; }
      footer { padding: 20px 16px; }
    }

    /* ── Контактна форма ─── */
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 16px;
      background: var(--surface);
      padding: 20px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      font-family: var(--font-ui);
    }

    .contact-form label {
      font-size: 13px;
      color: var(--text-muted);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .contact-form .optional-note {
      font-size: 12px;
      color: var(--text-faint);
      font-style: italic;
    }

    .contact-form input,
    .contact-form textarea {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 11px 13px;
      border-radius: 6px;
      font-family: inherit;
      font-size: 15px;
      transition: border-color 0.15s ease;
    }

    .contact-form textarea {
      resize: vertical;
      min-height: 120px;
    }

    .contact-form input:focus,
    .contact-form textarea:focus {
      outline: none;
      border-color: var(--accent);
    }

    .contact-form input::placeholder,
    .contact-form textarea::placeholder {
      color: var(--text-faint);
    }

    .contact-form button {
      background: var(--accent);
      color: #fff;
      border: none;
      padding: 13px;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 600;
      font-size: 15px;
      font-family: inherit;
      transition: opacity 0.2s;
    }

    .contact-form button:hover { opacity: 0.85; }
    .contact-form button:active { opacity: 0.7; }
  </style>
</head>
