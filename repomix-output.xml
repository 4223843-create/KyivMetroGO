<style id="critical-theme">
    html, body { background: #000000; } /* Темна за замовчуванням */
    
    /* Якщо примусово увімкнена світла: */
    html[data-theme="light"], 
    html[data-theme="light"] body { background: #e5e5ea; }
    
    /* Якщо системна світла І користувач не вибрав примусово темну: */
    @media (prefers-color-scheme: light) { 
      html:not([data-theme="dark"]), 
      html:not([data-theme="dark"]) body { background: #e5e5ea; } 
    }



    
    /* Лоадер має висіти НАД картою, а не штовхати її */
    .loader-container {
      position: fixed;
      inset: 0; /* Розтягуємо на весь екран (top:0; left:0; right:0; bottom:0) */
      z-index: 9999;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #000000; /* Закриваємо карту фоном, поки вона крива */
    }
    
    /* Підтримуємо світлу тему для фону лоадера */
    html[data-theme="light"] .loader-container { background: #e5e5ea; }
    @media (prefers-color-scheme: light) { 
      html:not([data-theme="dark"]) .loader-container { background: #e5e5ea; } 
    }

    .loader-container.hidden {
      display: none;
    }
    
    .loader-container svg {
      width: 120px; /* Фіксуємо розмір, бо інакше флекс розтягне його на весь екран */
      height: 120px;
    }
    /* Базовий колір пелюсток SVG — JS одразу перезаписує, але до старту анімації */
    .loader-container .st4 { fill: #1a1a1a; }
    @media (prefers-color-scheme: light) {
      .loader-container .st4 { fill: #c8c8cc; }
    }
    [data-theme="light"] .loader-container .st4 { fill: #c8c8cc; }
    [data-theme="dark"]  .loader-container .st4 { fill: #1a1a1a; }
</style>
<script>
    /* Миттєво застосовуємо збережену тему ДО малювання сторінки браузером */
