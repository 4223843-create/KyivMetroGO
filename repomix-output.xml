// ══ DOM-ВУЗЛИ ════════════════════════════════════════════════

const favSheet     = document.getElementById('favSheet');
const favBody      = document.getElementById('favBody');
const favClose     = document.getElementById('favClose');
const sheetOverlay = document.getElementById('sheetOverlay');

// ══ ПОРОЖНІЙ СТАН ════════════════════════════════════════════

