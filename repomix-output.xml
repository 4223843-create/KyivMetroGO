    const getColor = (prop, fallback) => {
      const val = rs.getPropertyValue(prop).trim();
      return val ? val : fallback;
    };

    const THEME_COLORS = { 
      red:   getColor('--line-red', '#c8523a'), 
      blue:  getColor('--line-blue', '#5b9bd5'), 
      green: getColor('--line-green', '#5aaa6a'), 
      base:  getColor('--bg-card', '#2c2c2e')
    };

    const hexToRgb = hex => { const n = parseInt(hex.replace('#',''), 16); return [(n>>16)&255, (n>>8)&255, n&255]; };
    const lerp = (a, b, t) => Math.round(a + (b - a) * t);
    const mixColors = (c, b, t) => { const [r1,g1,b1]=hexToRgb(c); const [r2,g2,b2]=hexToRgb(b); return `rgb(${lerp(r2,r1,t)},${lerp(g2,g1,t)},${lerp(b2,b1,t)})`; };

    const svg = document.getElementById('saluteSvg');
    const petalsUnsorted = Array.from(svg.querySelectorAll('.st4'));
    const center = svg.querySelector('.eggCenter');
    const cb = center.getBoundingClientRect();
    const cx = cb.left + cb.width/2, cy = cb.top + cb.height/2;

    const petals = petalsUnsorted.map(p => {
      const b = p.getBoundingClientRect();
      const a = Math.atan2(b.top+b.height/2 - cy, b.left+b.width/2 - cx) * 180 / Math.PI;
      return { el: p, a: (a+90+360)%360 };
    }).sort((a,b) => a.a - b.a).map(p => p.el);

    petals.forEach(p => { p.style.fill = THEME_COLORS.base; p.style.transition = "fill 0.25s ease"; });

    const schemes = [
      { c: THEME_COLORS.red, p: [THEME_COLORS.blue, THEME_COLORS.green] },
      { c: THEME_COLORS.blue, p: [THEME_COLORS.red, THEME_COLORS.green] },
      { c: THEME_COLORS.green, p: [THEME_COLORS.red, THEME_COLORS.blue] }
    ];
    const s = schemes[Math.floor(Math.random() * schemes.length)];

    const runPetals = () => {
      const i = Math.floor(Math.random() * petals.length);
      petals[i].style.fill = mixColors(s.p[i%2], THEME_COLORS.base, 0.85);
      setTimeout(() => { petals[i].style.fill = THEME_COLORS.base; }, 400);
      setTimeout(runPetals, 150 + Math.random() * 200);
    };
    const runCenter = () => {
      const ph = (Date.now()/1000)%1.2;
      center.style.fill = mixColors(s.c, THEME_COLORS.base, 0.35 + Math.abs(Math.sin(ph*Math.PI))*0.65);
      requestAnimationFrame(runCenter);
    };

    runPetals(); runCenter();
  </script>
