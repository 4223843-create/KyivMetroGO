<script>
  (function startLoader() {
    const viewport = document.getElementById("mapViewport");
const center = document.getElementById("loaderCenter");
    const petalGroup = document.getElementById("loaderPetals");    if (!viewport || !center || !petalGroup) return;

    const petalNodes = Array.from(petalGroup.querySelectorAll("path"));



    // Отримуємо координати центру (для сортування пелюсток)
    const centerBox = center.getBoundingClientRect();
    const centerX = centerBox.left + centerBox.width / 2;
    const centerY = centerBox.top + centerBox.height / 2;

    // Сортуємо пелюстки за годинниковою стрілкою
    const petals = petalNodes.map(petal => {
      const box = petal.getBoundingClientRect();
      const x = box.left + box.width / 2;
      const y = box.top + box.height / 2;
      let angle = Math.atan2(y - centerY, x - centerX) * 180 / Math.PI;
      let adjustedAngle = (angle + 90 + 360) % 360;
      return { element: petal, angle: adjustedAngle };
    })
    .sort((a, b) => a.angle - b.angle)
    .map(p => p.element);

    petals.forEach(p => p.style.transition = "fill 0.15s ease");
    center.style.transition = "none";

    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const COLORS = {
      red:   "#c8523a",
      blue:  "#5b9bd5",
      green: "#5aaa6a",
      base:  isLight ? "#c8c8cc" : "#1a1a1a"
    };

    const SESSION_SCHEMES = [
      { center: COLORS.red,   petalColors: [COLORS.blue, COLORS.green] },
      { center: COLORS.blue,  petalColors: [COLORS.red, COLORS.green]  },
      { center: COLORS.green, petalColors: [COLORS.red, COLORS.blue]   }
    ];

    let sessionIndex = 0;
    try {
      sessionIndex = parseInt(localStorage.getItem('appLoaderThemeIndex')) || 0;
      localStorage.setItem('appLoaderThemeIndex', (sessionIndex + 1) % SESSION_SCHEMES.length);
    } catch (e) {}

    const currentScheme = SESSION_SCHEMES[sessionIndex];
    petals.forEach(p => p.style.fill = COLORS.base);
    center.style.fill = currentScheme.center;

    function hexToRgb(hex) {
      const n = parseInt(hex.slice(1), 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function lerp(a, b, t) {
      return Math.round(a + (b - a) * t);
    }

    function mixColors(colorHex, baseHex, t) {
      const [r1, g1, b1] = hexToRgb(colorHex);
      const [r2, g2, b2] = hexToRgb(baseHex);
      return `rgb(${lerp(r2, r1, t)},${lerp(g2, g1, t)},${lerp(b2, b1, t)})`;
    }

    const TAIL_LENGTH   = 5;
    const ANIMATION_SPEED = 90;
    const HEARTBEAT_SPEED = 20;
    const BPM           = 60;
    const CYCLE         = 60 / BPM;
    const MIN_INTENSITY = 0.35;
    const MAX_INTENSITY = 0.85;

    function gauss(t, center, width, height) {
      return height * Math.exp(-Math.pow((t - center) / width, 2));
    }

    const startTimestamp = Date.now();
    let tail = [];
    let loaderTimeout = null;

    function getRandomPetal() {
      return Math.floor(Math.random() * petals.length);
    }

    function getRandomInterval() {
      return 300 + Math.random() * 400;
    }

    function animatePetal(petalIndex) {
      const colorIndex = Math.floor(Math.random() * currentScheme.petalColors.length);
      const petalColor = currentScheme.petalColors[colorIndex];
      tail.unshift({ petalIndex, color: petalColor, intensity: 1.0 });
      if (tail.length > TAIL_LENGTH) tail.length = TAIL_LENGTH;

      petals.forEach(p => p.style.fill = COLORS.base);
      tail.forEach((segment, i) => {
        const t = 1 - (i / TAIL_LENGTH) * 0.85;
        petals[segment.petalIndex].style.fill = mixColors(segment.color, COLORS.base, t);
      });
    }

    function animateLoader() {
      if (!viewport.classList.contains('is-loading')) {
        if (loaderTimeout) clearTimeout(loaderTimeout);
        return;
      }

      const randomPetal = getRandomPetal();
      const nextInterval = getRandomInterval();
      
      animatePetal(randomPetal);

      loaderTimeout = setTimeout(animateLoader, nextInterval);
    }

    function animateCenterHeartbeat() {
      if (!viewport.classList.contains('is-loading')) return;

      const phase = ((Date.now() - startTimestamp) / 1000 % CYCLE) / CYCLE;
      const wave = Math.min(1.0, gauss(phase, 0.15, 0.045, 1.0) + gauss(phase, 0.30, 0.060, 0.55) + gauss(phase, 0.22, 0.035, 0.20));
      const intensity = MIN_INTENSITY + wave * (MAX_INTENSITY - MIN_INTENSITY);

      center.style.fill = mixColors(currentScheme.center, COLORS.base, intensity);
      setTimeout(animateCenterHeartbeat, HEARTBEAT_SPEED);
    }

    animateCenterHeartbeat();
    setTimeout(animateLoader, 200);
  })();
</script>
<script>
  // Цей радар зловить помилку ДО запуску модулів і покаже її на екрані
  window.addEventListener('error', function(e) {
    alert('CRASH: ' + (e.message || e.error));
    document.getElementById('startupLoader').style.display = 'none';
  });
  window.addEventListener('unhandledrejection', function(e) {
    alert('PROMISE CRASH: ' + e.reason);
    document.getElementById('startupLoader').style.display = 'none';
  });
</script>

<script type="module" src="/src/main.js"></script>
</body>
