/* 5. Двоколірний повзунок для вікна "Про додаток" */
.about-station-sheet .sheet-handle {
background: linear-gradient(to right, var(--line-blue) 50%, var(--line-green) 50%);
}



/* =========================================
   ІНДИВІДУАЛЬНІ ВІДСТУПИ ДЛЯ КОЖНОГО ВІКНА
