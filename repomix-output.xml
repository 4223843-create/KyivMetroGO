/* КНОПКА ТА ПОВІДОМЛЕННЯ (Без змін) */
.fb-send-btn { width: 100%; margin: 16px 0 8px; padding: 12px 13px 14px; background: var(--bg-card); color: var(--text); border: 0.5px solid var(--border); border-radius: 12px; font-size: var(--fs-md); font-weight: var(--fw-semi); cursor: pointer; }
